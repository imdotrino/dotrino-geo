# Puerto HTTP del servicio
PORT=8090

# Conexión PostGIS. Si se omite, usa las PG* estándar del entorno.
DATABASE_URL=postgres://geo:geo@localhost:5432/geo

# Cap del TTL de un pin (ms). El cliente propone expiresAt; el server lo limita.
# 24h = alineado con la ventana de mensajes offline del proxy (el pin es un
# anuncio efímero; sin republicar, no sobrevive más que un mensaje offline).
GEO_MAX_TTL_MS=86400000

# Tolerancia de reloj para anti-replay del sobre firmado (ms).
GEO_CLOCK_SKEW_MS=300000

# Rate limit por IP (generoso; token bucket). capacity por minuto por IP.
# Lecturas (GET /pins) y escrituras (PUT/DELETE) en cubetas separadas.
GEO_RL_READ_PER_MIN=600
GEO_RL_WRITE_PER_MIN=120
# GEO_RL_DISABLED=1   # desactivar el rate limit por completo
# GEO_TRUST_PROXY=0   # si el server se expone SIN nginx delante (usa el socket)
