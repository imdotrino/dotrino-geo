# Copiá a `.env` y completá. Lo lee docker-compose.yml.

# Tu dominio para el nodo (debe apuntar A/AAAA a este host; 80/443 abiertos).
GEO_DOMAIN=geo.tudominio.com

# Contraseña fuerte de la base (la usa el server y Postgres). Generá una:
#   openssl rand -hex 24
GEO_DB_PASSWORD=cambiame

# Opcionales (defaults razonables):
GEO_MAX_TTL_MS=86400000
GEO_RL_READ_PER_MIN=600
GEO_RL_WRITE_PER_MIN=120

# --- Federación (opcional): replicar pines con otros nodos ---
# Lista separada por comas de URLs base de nodos peer. Tu nodo les empuja sus
# pines/borrados firmados y se sincroniza con ellos (da igual a cuál consulte el
# cliente: todos convergen). Los pines van firmados → no necesitás confiar en el peer.
# GEO_PEERS=https://geo.otrodominio.com,https://geo.tercero.org
# Token compartido para autenticar el tráfico nodo-a-nodo (recomendado si federás):
# GEO_REPLICATION_TOKEN=un-secreto-compartido-entre-los-nodos
# GEO_ANTI_ENTROPY_MS=30000
